rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the authenticated user's email is in the admin whitelist
    function isAdmin() {
      return request.auth != null && 
        (request.auth.token.email == 'metodopame.homedetail@gmail.com' || 
         request.auth.token.email == 'contactosaintdac@gmail.com');
    }

    // Check if the authenticated user is the owner of the document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Check if the specialist account exists and is active in Firestore
    // Note: requires employee document ID to be their Firebase Auth UID.
    // Optimization note for future scale: cache status in custom claims to save Firestore read cost.
    function isEmployeeActive() {
      return request.auth != null
        && exists(/databases/$(database)/documents/employees/$(request.auth.uid))
        && get(/databases/$(database)/documents/employees/$(request.auth.uid)).data.status == 'active';
    }

    // Rules for Specialists (Employees)
    match /employees/{employeeId} {
      // Anyone can submit a recruitment application form
      // But it MUST be submitted as status='pending' and active=false for safety
      allow create: if request.resource.data.status == 'pending' 
                    && request.resource.data.active == false;
      
      // Admins have full access
      allow read, write: if isAdmin();
      
      // Active specialists can read their own profile data and request updates (cannot change status, active flag or email)
      allow read: if isOwner(employeeId);
      allow update: if isOwner(employeeId)
                    && request.resource.data.status == resource.data.status
                    && request.resource.data.active == resource.data.active
                    && request.resource.data.email == resource.data.email;
    }

    // Rules for Clients and bookings
    match /users/{userId} {
      allow read, write: if isAdmin() || isOwner(userId);
      
      match /profile/triage {
        allow read, write: if isAdmin() || isOwner(userId);
      }
      
      match /bookings/{bookingId} {
        allow read, write: if isAdmin() || isOwner(userId);
      }
      
      match /concierge_requests/{requestId} {
        allow read, write: if isAdmin() || isOwner(userId);
      }
    }

    // Rules for Specialist calendars / schedules
    match /employee_schedules/{employeeId}/blocks/{dateStr} {
      // Clients need to query availability in real-time during triage booking
      allow read: if true;
      // Only admins can manually block/unblock slots
      allow write: if isAdmin();
    }

    // Rules for Referrals
    match /referrals/{referralId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == resource.data.referrerId);
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }
    // Rules for AI Concierge Chats
    match /chats/{userId} {
      allow read, write: if isAdmin() || isOwner(userId);
      
      match /messages/{messageId} {
        allow read, write: if isAdmin() || isOwner(userId);
      }
    }

    // Rules for AI Concierge — Global Reservation Index
    // Clients can write their own bookings to this index (PricingMatrix mirror).
    // Admins can read/write all. Server-side (Firebase Admin SDK) bypasses these rules.
    match /reservas_index/{bookingId} {
      // Clients can create their own index entry (needed for PricingMatrix)
      allow create: if request.auth != null;
      // Only admins can read or modify index entries from the client
      allow read, update, delete: if isAdmin();
    }

    // Rules for Waitlist
    match /waitlist/{entryId} {
      // Anyone can register on the waitlist
      allow create: if true;
      // Only admins can read, update or delete waitlist entries
      allow read, update, delete: if isAdmin();
    }

    // Rules for collectionGroup bookings (enables fetching all bookings for admins, and assigned bookings for specialists)
    match /{path=**}/bookings/{bookingId} {
      allow read, write: if isAdmin();
      allow read: if request.auth != null 
                    && resource.data.assignedEmployeeId != null
                    && exists(/databases/$(database)/documents/employees/$(resource.data.assignedEmployeeId))
                    && request.auth.token.email == get(/databases/$(database)/documents/employees/$(resource.data.assignedEmployeeId)).data.email;
    }

    // ─── RULES FOR TRAINING SYSTEM (LMS) ──────────────────────────────────────────
    
    // Modules, lessons, and evaluations are readable by active specialists and admins, writeable by admin
    match /modules/{moduleId} {
      allow read: if isEmployeeActive() || isAdmin();
      allow write: if isAdmin();
    }
    match /lessons/{lessonId} {
      allow read: if isEmployeeActive() || isAdmin();
      allow write: if isAdmin();
    }
    match /evaluations/{evaluationId} {
      allow read: if isEmployeeActive() || isAdmin();
      allow write: if isAdmin();
    }

    // Training progress subcollection is readable and writeable by the specialist owner and admin
    match /employees/{employeeId}/trainingProgress/{progressId} {
      allow read: if isOwner(employeeId) || isAdmin();
      allow write: if isOwner(employeeId) || isAdmin();
    }

    // Final exam attempts can only be read by the specialist owner and admin
    // Writes are blocked for clients (only created/graded server-side via Firebase Admin SDK)
    match /employees/{employeeId}/final_exam_attempts/{attemptId} {
      allow read: if isOwner(employeeId) || isAdmin();
      allow write: if false;
    }

    // Final exam questions (synthesis) are never readable by clients (only read by Admin SDK)
    match /final_exam_questions/{questionId} {
      allow read: if false;
      allow write: if isAdmin();
    }

    // Certifications are publicly readable (for verification) and writeable by admin
    match /certifications/{certificationId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
