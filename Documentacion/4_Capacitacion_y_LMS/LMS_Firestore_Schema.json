  "completionCriteriaTypes": {
    "description": "Los dos tipos de criterio de completitud de lección. Esto define la complejidad de implementación.",

    "manual_confirmation": {
      "appliesTo": "lessons with type = 'reading'",
      "ux": "Botón 'Marcar como lida' al final de la lección. Click → status = 'completed'.",
      "implementation": {
        "frontendEvent": "onClick del botón",
        "firestoreWrite": "1 write por lección completada",
        "trackingRequired": false,
        "videoPlayerRequired": false,
        "complexity": "baja"
      },
      "fields": {
        "type": "manual_confirmation",
        "buttonLabel": "Marcar como lida",
        "thresholdPercent": null,
        "requiresVideoWatch": false
      }
    },

    "video_watch_threshold": {
      "appliesTo": "lessons with type = 'video' or 'hybrid'",
      "ux": "Player de video con barra de progreso. Cuando videoProgressPercent >= 90, lección se marca automáticamente como completed. Botón 'Próxima lição' se desbloquea.",
      "implementation": {
        "frontendEvent": "onTimeUpdate del video player cada 5 segundos (debounced)",
        "firestoreWrite": "writes periódicos cada 5 segundos + 1 write final al llegar a 90%",
        "trackingRequired": true,
        "videoPlayerRequired": true,
        "complexity": "media",
        "notes": "Implementar debounce de 5 segundos para no quemar writes en Firestore. Considerar también guardar el progreso en localStorage por si la especialista se desconecta."
      },
      "fields": {
        "type": "video_watch_threshold",
        "thresholdPercent": 90,
        "buttonLabel": null,
        "requiresVideoWatch": true
      }
    }
  },

  "securityRulesHelpers": {
    "description": "Funciones helper para las security rules de Firestore.",
    "code": "rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    function isFounder() {\n      return request.auth != null && request.auth.token.role == 'FOUNDER';\n    }\n\n    function isEmployeeActive() {\n      return request.auth != null\n        && exists(/databases/{database}/documents/employees/$(request.auth.uid))\n        && get(/databases/{database}/documents/employees/$(request.auth.uid)).data.status == 'active';\n    }\n\n    function isOwner(employeeId) {\n      return request.auth != null && request.auth.uid == employeeId;\n    }\n\n    match /modules/{moduleId} {\n      allow read: if isEmployeeActive() || isFounder();\n      allow write: if isFounder();\n    }\n\n    match /lessons/{lessonId} {\n      allow read: if isEmployeeActive() || isFounder();\n      allow write: if isFounder();\n    }\n\n    match /evaluations/{evaluationId} {\n      allow read: if isEmployeeActive() || isFounder();\n      allow write: if isFounder();\n    }\n\n    match /employees/{employeeId}/trainingProgress/{progressId} {\n      allow read: if isOwner(employeeId) || isFounder();\n      allow write: if isOwner(employeeId) || isFounder();\n    }\n\n    match /certifications/{certificationId} {\n      allow read: if true;\n      allow write: if isFounder();\n    }\n\n    match /final_exam_questions/{questionId} {\n      allow read: if isEmployeeActive() || isFounder();\n      allow write: if isFounder();\n    }\n\n    match /final_exam_attempts/{attemptId} {\n      allow read: if isOwner(employeeId) || isFounder();\n      allow write: if isOwner(employeeId) || isFounder();\n    }\n  }\n}"
  },

  "certificateSpec": {
    "description": "Especificaciones visuales canónicas del certificado (del brand-book).",
    "format": "PDF generado client-side con @react-pdf/renderer",
    "palette": {
      "background": "#561668",
      "accent": "#C9A84C",
      "text": "#FFFFFF",
      "logoVersion": "white"
    },
    "typography": {
      "font": "Manrope",
      "weight": "regular, bold",
      "case": "uppercase for headers, normal for body",
      "note": "NO usar Cormorant Garamond — esa tipografía es exclusiva para headings de landing de clientas."
    },
    "fields": {
      "header": "CERTIFICADO",
      "subtitle": "Método Pame | Home Detail",
      "body": "Certificamos que [NOME DA ESPECIALISTA] completou o curso de formação do Método Pame | Home Detail, com aproveitamento de [SCORE]% no exame final, e está habilitada a atuar como especialista certificada do método.",
      "footer": "Emitido em [DATA]. Código de verificação: [CERTIFICATION_CODE].",
      "signature": "Pame — Fundadora, Método Pame"
    },
    "verificationUrl": "metodopame.com/verificar-certificado/{certificateCode}"
  },

  "certificationLevels": {
    "Certificada Método Pame": {
      "condition": "finalExamScore >= 90 AND modulesCompleted == 15",
      "employeeStatus": "trainingStatus = 'certified', certificationLevel = 'Certificada Método Pame'",
      "permission": "Puede ser asignada sola a residencias de alto estándar."
    },
    "Em Formação": {
      "condition": "finalExamScore >= 70 AND finalExamScore < 90 AND modulesCompleted == 15",
      "employeeStatus": "trainingStatus = 'completed', certificationLevel = 'Em Formação'",
      "permission": "Puede hacer pasantía con especialista senior. NO puede ser asignada sola."
    },
    "No certificada": {
      "condition": "finalExamScore < 70 OR modulesCompleted < 15",
      "employeeStatus": "trainingStatus = 'in_progress'",
      "permission": "No puede ser asignada a ninguna residencia."
    }
  },

  "namingConventions": {
    "moduleId": "mod_NN (ej: mod_01 a mod_15, siempre 2 dígitos)",
    "lessonId": "les_{mod}_{lesson} (ej: les_08_02)",
    "evaluationId": "eva_{mod} (ej: eva_08)",
    "questionId": "q_{mod}_{n} (ej: q_08_01)",
    "progressId": "{employeeId}_{moduleId} (ej: emp_001_mod_08)",
    "certificateCode": "MP-CERT-{year}-{employeeId}-{random6} (ej: MP-CERT-2026-emp_001-A4B7C9)",
    "slug": "kebab-case PT-BR (ej: cuidado-de-marmore-e-pedras-nobres)",
    "timestamps": "ISO 8601 UTC en JSON, Firestore timestamps en la base"
  },

