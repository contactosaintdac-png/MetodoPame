        "description":    { "type": "string",  "required": true,  "example": "Apresentação do método, da Pame e do que significa ser 'do Método'." },
        "objective":      { "type": "string",  "required": true,  "example": "Que a especialista entenda o que é o Método Pame, quem é Pame, e o que significa representá-lo." },
        "block":          { "type": "string",  "required": true,  "enum": ["identidad", "postura", "conducta", "tecnica", "estandar", "operacion"] },
        "estimatedMinutes": { "type": "number", "required": true, "example": 30 },
        "lessons":        { "type": "array",   "required": true,  "items": { "type": "string" }, "example": ["les_01_01", "les_01_02", "les_01_03"], "description": "IDs de lecciones en orden." },
        "evaluationId":   { "type": "string",  "required": true,  "example": "eva_01" },
        "prerequisiteModuleId": { "type": ["string", "null"], "required": true, "example": null, "description": "ID del módulo previo. null para módulo 1." },
        "order":          { "type": "number",  "required": true,  "example": 1 },
        "status":         { "type": "string",  "required": true,  "enum": ["draft", "published"], "default": "draft" },
        "createdAt":      { "type": "timestamp", "required": true, "firestoreType": "FieldValue.serverTimestamp()" },
        "updatedAt":      { "type": "timestamp", "required": true, "firestoreType": "FieldValue.serverTimestamp()" }
      },
      "indexes": [
        { "fields": ["number"], "order": "asc" },
        { "fields": ["block", "order"], "order": "asc" },
        { "fields": ["status"], "order": "asc" }
