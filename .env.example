# Variables de entorno — Método Pame
# Copiar este archivo como .env.local y rellenar con los valores reales
# NUNCA commitear .env.local al repositorio

# ─── Firebase (Frontend / Client SDK) ─────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Firebase Admin SDK (Vercel Serverless Functions) ─────────────────────────
# Obtener desde Firebase Console → Configuración → Cuentas de servicio → Generar clave
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── Resend (Emails transaccionales) ──────────────────────────────────────────
RESEND_API_KEY=

# ─── Mercado Pago (Pagos Pix + Cartão) ────────────────────────────────────────
MP_ACCESS_TOKEN=

# ─── Google Calendar API ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=

# ─── WhatsApp (Meta Cloud API) ────────────────────────────────────────────────
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ─── Analytics (opcionales) ───────────────────────────────────────────────────
VITE_GOOGLE_ANALYTICS_ID=
VITE_META_PIXEL_ID=
VITE_CLARITY_ID=
