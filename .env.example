# Variables de entorno — Método Pame
# Copiar este archivo como .env.local y rellenar con los valores reales
# NUNCA commitear .env.local al repositorio (ya está en .gitignore)

# ─── Firebase (Frontend / Client SDK) ─────────────────────────────────────────
# Estas van en .env.local para desarrollo local Y en Vercel para producción
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Google Calendar (Frontend) ───────────────────────────────────────────────
# ID del calendario de Pame (público, va en frontend)
VITE_GOOGLE_CALENDAR_ID=

# ─── NVIDIA API (si se usa para algún feature de IA) ──────────────────────────
NVIDIA_API_KEY=

# ─── Solo en Vercel (NO necesarias en .env.local para desarrollo local) ───────
# Estas variables están configuradas directamente en el dashboard de Vercel.
# Solo se necesitan localmente si se quiere testear las Serverless Functions con `vercel dev`.

# Firebase Admin SDK (Vercel Serverless Functions — api/lms.ts, api/send-*.ts, etc.)
# Obtener desde Firebase Console → Configuración → Cuentas de servicio → Generar clave privada
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Resend (Emails transaccionales)
# RESEND_API_KEY=

# Mercado Pago (Pagos Pix + Cartão)
# MP_ACCESS_TOKEN=

# Google Calendar API (OAuth para crear eventos — api/create-calendar-event.ts)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=

# WhatsApp (Meta Cloud API — api/send-whatsapp.ts)
# WHATSAPP_API_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# Analytics (opcionales — solo si están configurados en el proyecto)
# VITE_GOOGLE_ANALYTICS_ID=
# VITE_META_PIXEL_ID=
# VITE_CLARITY_ID=
