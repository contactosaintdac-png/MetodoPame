      replacement_content: "@import \"tailwindcss\";\n\n@theme {\n  --font-sans: \"Manrope\", ui-sans-serif, system-ui, sans-serif;\n  \n  /* Atomsfera PAME 2.0 / Silk & Stone Palette */\n  --color-primary: #561668;\n  --color-primary-container: #703081;\n  --color-on-primary: #ffffff;\n  --color-on-primary-container: #eca1fb;\n  --color-inverse-primary: #f2afff;\n  \n  --color-secondary: #5d5e60;\n  --color-on-secondary: #ffffff;\n  --color-secondary-container: #e0dfe1;\n  --color-on-secondary-container: #626264;\n  \n  --color-tertiary: #38333d;\n  --color-on-tertiary: #ffffff;\n  --color-tertiary-container: #4f4a54;\n  --color-on-tertiary-container: #c2bac6;\n  \n  --color-background: #fff7fd;\n  --color-on-background: #1e1a20;\n  \n  --color-surface: #fff7fd;\n  --color-on-surface: #1e1a20;\n  --color-on-surface-variant: #4e434e;\n  \n  --color-surface-dim: #e0d7e0;\n  --color-surface-bright: #fff7fd;\n  --color-surface-container-lowest: #ffffff;\n  --color-surface-container-low: #faf1fa;\n  --color-surface-container: #f4ebf4;\n  --color-surface-container-high: #efe5ee;\n  --color-surface-container-highest: #e9e0e8;\n  --color-surface-variant: #e9e0e8;\n  \n  --color-outline: #80737f;\n  --color-outline-variant: #d1c2d0;\n  \n  --color-error: #ba1a1a;\n  --color-on-error: #ffffff;\n  --color-error-container: #ffdad6;\n  --color-on-error-container: #93000a;\n}\n\n@layer utilities {\n  /* Silk Soft Neumorphic utilities adjusted for Atmosfera PAME 2.0 Palette */\n  .neu-raised {\n    box-shadow: 6px 6px 12px #d9cbd9, -6px -6px 12px #ffffff;\n  }\n  \n  .neu-pressed {\n    box-shadow: inset 4px 4px 8px #d9cbd9, inset -4px -4px 8px #ffffff;\n  }\n  \n  .neu-button {\n    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);\n    box-shadow: 4px 4px 8px #d9cbd9, -4px -4px 8px #ffffff;\n  }\n  \n  .neu-button:active {\n    box-shadow: inset 2px 2px 5px #d9cbd9, inset -2px -2px 5px #ffffff;\n  }\n  \n  .neu-hover:hover {\n    box-shadow: 2px 2px 5px #d9cbd9, -2px -2px 5px #ffffff;\n    transform: translateY(1px);\n  }\n  \n  .neu-active:active {\n    box-shadow: inset 4px 4px 8px #d9cbd9, inset -4px -4px 8px #ffffff;\n  }\n  \n  .silk-shadow {\n    box-shadow: 0 4px 20px -2px rgba(112, 48, 129, 0.08), 0 2px 8px -2px rgba(112, 48, 129, 0.04);\n  }\n}\n\n/* Scrollbar styling */\n::-webkit-scrollbar {\n  width: 6px;\n  height: 6px;\n}\n::-webkit-scrollbar-track {\n  background: #faf1fa;\n}\n::-webkit-scrollbar-thumb {\n  background: #d1c2d0;\n  border-radius: 10px;\n}\n::-webkit-scrollbar-thumb:hover {\n  background: #80737f;\n}"
