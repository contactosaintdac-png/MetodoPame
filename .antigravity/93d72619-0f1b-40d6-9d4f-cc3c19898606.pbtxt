      target_content: "import { useState } from \'react\';\nimport { motion, AnimatePresence } from \'motion/react\';\nimport { TriageData, AddonService } from \'../types\';\nimport { PAME_ADDONS } from \'../data\';\n\ninterface PricingMatrixProps {\n  triageData: TriageData;\n  onTriageDataChange: (data: TriageData) => void;\n}\n\nexport default function PricingMatrix({ triageData, onTriageDataChange }: PricingMatrixProps) {\n  const [selectedFormat, setSelectedFormat] = useState<\'meio\' | \'completo\'>(\n    triageData.frequency === \'monthly\' ? \'completo\' : \'meio\'\n  );\n  const [selectedPlanMode, setSelectedPlanMode] = useState<\'avulso\' | \'mensal\'>(\n    triageData.frequency === \'monthly\' ? \'mensal\' : \'avulso\'\n  );\n  const [activeAddons, setActiveAddons] = useState<string[]>([]);\n  const [showBookingModal, setShowBookingModal] = useState(false);\n  const [bookingName, setBookingName] = useState(\'\');\n  const [bookingPhone, setBookingPhone] = useState(\'\');\n  const [bookingDateState, setBookingDateState] = useState(\'\');\n  const [bookingSuccess, setBookingSuccess] = useState(false);\n\n  // Surface treatment overhead estimation (luxury Order care)\n  const surfaceCount = [\n    triageData.marble,\n    triageData.wood,\n    triageData.doubleGlass,\n    triageData.chandeliers,\n  ].filter(Boolean).length;\n\n  const toggleAddon = (id: string) => {\n    setActiveAddons((prev) =>\n      prev.includes(id) ? prev.filter((item) => item !== id) : [...prev, id]\n    );\n  };\n\n  // Base pricing mapping from image\n  // Meio Turno: avulso = 250, mensal = 800 (for 4 sessions, which is 200 per session, saving 200/mo)\n  // Turno Completo: avulso = 450, mensal = 1500 (for 4 sessions, saving 300/mo)\n  const getBasePrice = (format: \'meio\' | \'completo\', mode: \'avulso\' | \'mensal\') => {\n    if (format === \'meio\') {\n      return mode === \'avulso\' ? 250 : 800;\n    } else {\n      return mode === \'avulso\' ? 450 : 1500;\n    }\n  };\n\n  const getSavings = (format: \'meio\' | \'completo\', mode: \'avulso\' | \'mensal\') => {\n    if (mode === \'avulso\') return 0;\n    return format === \'meio\' ? 200 : 300;\n  };\n\n  const basePrice = getBasePrice(selectedFormat, selectedPlanMode);\n  const savings = getSavings(selectedFormat, selectedPlanMode);\n  const addonsPrice = activeAddons.length * 50;\n  const luxuryCareFee = surfaceCount * 30; // Adding R$30 for custom fine-finishes luxury care\n  const totalPrice = basePrice + addonsPrice + luxuryCareFee;\n\n  const handleBookingSubmit = (e: React.FormEvent) => {"
