{
  "crons": [
    {
      "path": "/api/send-reminder",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/send-address-reveal",
      "schedule": "0 5 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/generate-final-exam",
      "destination": "/api/lms?action=generate-final-exam"
    },
    {
      "source": "/api/grade-final-exam",
      "destination": "/api/lms?action=grade-final-exam"
    },
    {
      "source": "/api/migrate-employees",
      "destination": "/api/lms?action=migrate-employees"
    },
    {
      "source": "/((?!api/|assets/).*)",
      "destination": "/index.html"
    }
  ]
}
